          RoundedButton:
               text: "Translate All"
               on_release:app.root.current="arabic2"

        


# Custom Reusable Rounded Button Component
<RoundedButton@Button>:
     background_color: 0, 0, 0, 0  # 1. Hides the default gray box texture
     background_normal: ''         # 2. Clears default button behavior tints
     color: 1, 1, 1, 1             # White text color
     font_size: '18sp'
     bold: True
     size_hint_y: None
     height: '60dp'                # Explicit touch-friendly mobile height

     canvas.before:
          Color:
            # Changes color dynamically when clicked (state is 'down')
               rgba: (0.12, 0.43, 0.93, 1) if self.state == 'normal' else (0.08, 0.33, 0.73, 1)
          RoundedRectangle:
               pos: self.pos
               size: self.size
               radius: [20]          # The corner roundness radius in pixels
          




<Video_a>:
     name:"a"
     id:a
     FloatLayout:
          
          ActionBar:
               pos_hint:{'top':1}
               ActionView:
                    use_separator:True
                    ActionPrevious:
                         title:'   Go Back'
                         on_press:
                              app.root.current="w_screen"
                         with_previous:False
                    ActionGroup:
                         mode:'spinner'
                         text:'Menu'
                         ActionButton:
                              text:'Grammar Page'
                         ActionButton
                              text:'Conversation'
                         ActionButton
                              text:'Vocabular Test'
                         ActionButton
                              text:'Phrasal Verbs'
                         ActionButton:
                              text:'Punctuation'
     
     VideoPlayer:
          id:v1
          source:
          pos_hint:{'top':1}
          state:'play'






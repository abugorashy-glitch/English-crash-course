<ArabicText>:
     name:"arabic"
     id:ar
     BoxLayout:
          padding: 50
          spacing: 10
          ScrollView:
               id: sv
               do_scroll_y: True
               do_scroll_x: False
               bar_width: '10dp'
               scroll_type: ['bars', 'content']
               TextInput:
                    id:myarab
                    text: 'choose lesson'
                    size_hint: None, None
                    size: sv.width - sv.bar_width, dp(450)
                    multiline: True
                    font_name:"data/arial.ttf"
     BoxLayout:
          Button:
               
               text:"Go Back"
               size_hint:(0.1,0.1)
               color:(1,1,1,1)
               background_color:(0,1,0,1)
               on_release:app.root.current="ww"

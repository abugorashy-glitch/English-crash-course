<ShowPunctuation>:
     name:'showpunc'
     id:show1
     BoxLayout:
          padding: 50
          spacing: 10
          ScrollView:
               id: sv
               do_scroll_y: True
               do_scroll_x: False
               bar_width: '10dp'
               scroll_type: ['bars', 'content'] 
               TextInput:
                    id:punc1
                    text: 'choose lesson'
                    size_hint: None, None
                    size: sv.width - sv.bar_width, dp(450)
                    height:390
                    width:3000
                    
                    multiline: True
                    foreground_color:(0.3,0.4,0.5,1)
                    font_name:"data/arial.ttf"
     BoxLayout:  
          Button:
               size_hint:(0.1,0.1)
               color:(1,1,1,1)
               background_color:(0,1,0,1)
               text:"Go Back"
               on_press:
                    app.root.current="punc1"


<Translation>:
     name:"trans"
     id:t
     BoxLayout:
          padding: 50
          spacing: 10
          ScrollView:
               id: sv
               do_scroll_y: True
               do_scroll_x: False
               bar_width: '10dp'
               scroll_type: ['bars', 'content'] 
               TextInput:
                    id:my
                    text: 'choose lesson'
                    size_hint: None, None
                    size: sv.width - sv.bar_width, dp(450)
                    multiline: True
                    foreground_color:(1,0,0,1)
                    font_name:"data/arial.ttf"
     BoxLayout:
          Button:
               
               text:"Go Back"
               size_hint:(0.1,0.1)
               color:(1,1,1,1)
               background_color:(0,1,0,1)
               on_press:
                    root.checkwindow()




<SplashScreen>:
     name:'splash'
    
     BoxLayout:
          orientation: 'vertical'
          canvas.before:
               Color:
                    rgba: 0.1, 0.5, 0.8, 1  # Sky blue background
               Rectangle:
                    pos: self.pos
                    size: self.size
                
          BoxLayout:
               orientation: 'vertical'
               padding: 40
               spacing: 20

          Label:
               id: icon_label
               text: "📥"
               font_size: '60sp'
               size_hint_y: None
               height: '80dp'

          Label:
               id: status_label
               text: "Initializing configuration..."
               font_size: '18sp'
               color: 1, 1, 1, 1
               halign: 'center'
               size_hint_y: None
               height: '40dp'

          BoxLayout:
               id: progress_layout
               orientation: 'vertical'
               size_hint_y: None
               height: '60dp'
               spacing: 5
            
               ProgressBar:
                    id: progress_bar
                    max: 100
                    value: 0
                    size_hint_y: None
                    height: '20dp'
                
               Label:
                    id: percent_label
                    text: "0%"
                    font_size: '14sp'
                    color: 0.7, 0.7, 0.7, 1

          BoxLayout:
               id: retry_layout
               size_hint_y: None
               height: '50dp'
               opacity: 0
               disabled: True
            
               Button:
                    text: "🔄 Tap to Retry Setup"
                    font_size: '16sp'
                    background_normal: ''
                    background_color: 0.12, 0.43, 0.93, 1
                    on_release: root.start_download_process()
       





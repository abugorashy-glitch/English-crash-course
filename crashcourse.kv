                              text:'Explain'
                              on_release:
                                   app.root.current="showpunc"
                         
                         
     BoxLayout:
          orientation: 'vertical'
          Label:
               text:'Choose the correct answer'
               id:vocabu
               height:dp(30)
               text_size:self.size
               
          BoxLayout:
               size_hint_y:None
               heigh:dp(30)
               CheckBox:
                    id:check1
                    group:'mygroup'
                    size_hint_x:None
                    width:dp(32)
                    allow_no_selection:False
                    
                    
               Label:
                    id:punc1
                    text_size:self.size
                    halign:'left'
                    valign:'center'
                    text:''
                    

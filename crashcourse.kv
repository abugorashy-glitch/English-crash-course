<Punctuation3>:
     name:'punc3'
     id:p3
     FloatLayout:
          
          ActionBar:
               pos_hint:{'top':1}
               ActionView:
                    use_separator:True
                    ActionPrevious:
                         title:' Go Back'
                         on_press:
                              app.root.current="game_screen"
                         with_previous:False
                    ActionGroup:
                         mode:'spinner'
                         text:'Menu'
                         ActionButton:
                              text:'Move Next'
                              on_press:
                                   root.on_pre_enter()
                              on_press:
                                   root.on_estate_check()
                         ActionButton
                              text:'Stop Here'
                              on_release:

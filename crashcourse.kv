<MyScreenManager>:
     SplashScreen:
          name: 'splash'
     Firstwindow:
          name: 'home_screen'
     Secondwindow:
          name: "menu_screen"
     Thirdwindow:
          name: "game_screen"
     Windowfirst:
          name: "w_screen"
     Mywidget:
          name:"ww"
     Playvideo:
          name:"video"
     Mode:
          name:"con_a"
     Modea:
          name:"con_b"
     Video_a:
          name:"a"
     Video_b:
          name:"b"
     ArabicText:
          name:"arabic"
     ArabicText1:
          name:"arabic1"
     ArabicText2:
          name:"arabic2"
     GramarPage:
          name:"page1"
     GramarPage1:
          name:'page2'
     GramarPage2:
          name:'page3'
     PhrasalVerb:
          name:'phrasal' 
     PhrasalVerb1:
          name:'phrasal2' 
     PhrasalVerb2:
          name:'phrasal3' 
     ShowphrResult:
          name:'showphr'
     Vocabulary_a:
          name:"v"
     Vocabulary_b:
          name:"vocabu"
     Vocabulary_c:
          name:"v2"
     ShowVocabulary:
          name:"show_v"
     Punctuation1:
          name:'punc1'
     Punctuation2:
          name:'punc2'
     Punctuation3:
          name:'punc3'
     ShowPunctuation:
          name:'showpunc'
     Translation:
          name:"trans"

<Firstwindow>:
     name: "home_screen"
     id: home_screen
     canvas.before:
          Color:
               rgba: 0.95, 0.95, 0.95, 1
          Rectangle:
               pos: self.pos
               size: self.size

     BoxLayout:
          orientation: 'vertical'
          padding: [40, 60, 40, 60]  # Left/Right, Top/Bottom margins
          spacing: 25                # Space between the buttons

          Label:
               text: "English Crash Course"
               font_size: '28sp'
               bold: True
               color:  0, 0, 1, 1  # Sets background to blue
               size_hint_y: 0.3

          # Button 1: Settings
          RoundedButton:
               text: "Beginner Level"
               on_release:
                    app.root.transition.direction = 'right'
               
                    app.root.current="w_screen"

        # Button 2: Profile
          RoundedButton:
               text: "Intermediate Level"
               on_release:
                    app.root.transition.direction = 'right'
                    app.root.current="menu_screen"

        # Button 3: Exit
          RoundedButton:
               text: "Advanced Level"
               on_release:
                    app.root.transition.direction = 'right'
                    app.root.current="game_screen"


# Custom Reusable Rounded Button Component
<RoundedButton@Button>:
     background_color: 0, 0, 0, 0  # 1. Hides the default gray box texture
     background_normal: ''         # 2. Clears default button behavior tints
     color: 1, 1, 1, 1             # White text color
     font_size: '18sp'
     bold: True
     size_hint_y: None
     height: '60dp'                # Explicit touch-friendly mobile height

     canvas.before:
          Color:
            # Changes color dynamically when clicked (state is 'down')
               rgba: (0.12, 0.43, 0.93, 1) if self.state == 'normal' else (0.08, 0.33, 0.73, 1)
          RoundedRectangle:
               pos: self.pos
               size: self.size
               radius: [20]          # The corner roundness radius in pixels

          
     
               
<Secondwindow>:
     name: "menu_screen"
     id: menu_s
     
     FloatLayout:
          
          ActionBar:
               pos_hint:{'top':1}
               ActionView:
                    use_separator:True
                    ActionPrevious:
                         title:' Go Back'
                         on_press:
                              app.root.current="home_screen"
                         with_previous:False
                    
                       
                    ActionGroup:
                         mode:'spinner'
                         text:'Menu'
                         
                         ActionButton:
                              text:'Grammar Page'
                              
                              on_press:
                                   app.root.current="page2"
                         ActionButton
                              
                              text:'Listening'
                              on_release:
                                   app.root.current="con_a"
                         ActionButton
                              text:'Vocabulary Test'
                              
                              on_release:
                                   app.root.current="vocabu"
                         ActionButton
                              text:'Phrasal Verbs'
                              on_release:
                                   app.root.current="phrasal2"
                         ActionButton:
                              text:'punctuation'
                              on_release:
                                   app.root.current="punc2"
                         
                              
          
          
     BoxLayout:
          orientation: 'vertical'
          Label:
               text:''
               id:record1
               height:dp(30)
               text_size:self.size
          BoxLayout:
               size_hint_y:None
               heigh:dp(30)
               CheckBox:
                    id:check1
                    group:'mygroup'
                    size_hint_x:None
                    width:dp(32)
                    allow_no_selection:False
                    
                    
               Label:
                    id:ll1
                    text_size:self.size
                    halign:'left'
                    valign:'center'
                    text:''
                    
          BoxLayout:
               size_hint_y:None
               heigh:dp(30)
               CheckBox:
                    id:check2
                    group:'mygroup'
                    size_hint_x:None
                    width:dp(32)
                    id:check2
                    
               Label:
                    id:ll2
                    text_size:self.size
                    halign:'left'
                    valign:'center'
                    text:''
          BoxLayout:
               size_hint_y:None
               heigh:dp(30)
               CheckBox:
                    id:check3
                    group:'mygroup'
                    size_hint_x:None
                    width:dp(32)
                    id:check3
                    
               Label:
                    id:ll3
                    text_size:self.size
                    halign:'left'
                    valign:'center'
                    text:''
          BoxLayout:
               Label:
                    id:null
                    text_size:self.size
                    halign:'left'
                    valign:'center'
                    text:''
          
     BoxLayout:
               
           # Button 1: Settings
          RoundedButton:
               text: "Move Next"
               on_press: 
                    root.on_pre_enter()
               on_press:
                    root.on_estate_check()

        # Button 2: Profile
          RoundedButton:
               text: "STOPE HERE"
               on_press: 
                    root.stophere1()

        # Button 3: Exit
          RoundedButton:
               text: "Explain"
               on_press:
                    app.root.current="b"


